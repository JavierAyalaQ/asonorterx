---
interface Props {
  columns: string[];
  data: string[][];
  color?: "neutral" | "teal" | "blue" | "gray";
  mobileCollapse?: "scroll" | "fit";
}

const colorVariants = {
  neutral: {
    head: "bg-neutral-800 text-neutral-100 dark:bg-neutral-300 dark:text-neutral-900",
    divider: "divide-neutral-800 dark:divide-neutral-400",
    row: "bg-neutral-700 text-neutral-200 dark:bg-neutral-200 dark:text-neutral-800",
  },
  gray: {
    head: "bg-gray-900 text-gray-100 dark:bg-gray-300 dark:text-gray-900",
    divider: "divide-gray-700 dark:divide-gray-300",
    row: "bg-gray-800 text-gray-300 dark:bg-gray-200 dark:text-gray-800",
  },
  teal: {
    head: "bg-teal-950 text-teal-50 dark:bg-teal-300 dark:text-teal-950",
    divider: "divide-teal-700 dark:divide-teal-300",
    row: "bg-teal-900 text-teal-50 dark:bg-teal-100 dark:text-teal-900",
  },
  blue: {
    head: "bg-blue-950 text-blue-50 dark:bg-blue-300 dark:text-blue-950",
    divider: "divide-blue-950 dark:divide-blue-300",
    row: "bg-blue-900 text-blue-50 dark:bg-blue-100 dark:text-blue-900",
  },
};

const {
  columns,
  data,
  color = "neutral",
  mobileCollapse = "fit",
} = Astro.props;
---

<div class="relative overflow-x-auto rounded">
  <table
    class:list={[
      "text-xs md:text-md text-left",
      colorVariants[color].head,
      mobileCollapse === "scroll" ? "w-full" : "w-fit sm:w-full",
    ]}
  >
    <thead
      class:list={[
        "font-medium tracking-wide uppercase",
        colorVariants[color].head,
      ]}
    >
      <tr>
        {
          columns.map((column) => (
            <th scope="col" class="p-2 md:px-6 md:py-3">
              {column}
            </th>
          ))
        }
      </tr>
    </thead>

    <tbody class:list={["divide-y", colorVariants[color].divider]}>
      {
        data.map((item) => (
          <tr class:list={["", colorVariants[color].row]}>
            <th
              scope="row"
              class:list={[
                "p-2 md:px-6 md:py-4 font-bold",
                mobileCollapse === "scroll"
                  ? "w-full  whitespace-nowrap"
                  : "w-fit",
              ]}
            >
              {item[0]}
            </th>
            {item.slice(1).map((value) => (
              <td class="p-2 md:px-6 md:py-4">{value}</td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
